#!name=Bahamut 每日任务
#!desc=巴哈姆特登录、主页签到、公会签到、动画疯答题
#!author=Codex

[Script]
Bahamut 抓包 = type=http-request, pattern=^https://(www|api)\.gamer\.com\.tw/(mobile_app/user/v3/login|ajax/login|signin).*, requires-body=0, script-path=https://raw.githubusercontent.com/Lariya-aa/surge-auto-sign-modules/main/scripts/dist/gamer.js, timeout=10
Bahamut 每日任务 = type=cron, cronexp="0 8 * * *", script-path=https://raw.githubusercontent.com/Lariya-aa/surge-auto-sign-modules/main/scripts/dist/gamer.js, timeout=300

[MITM]
hostname = %APPEND% www.gamer.com.tw, api.gamer.com.tw, guild.gamer.com.tw, ani.gamer.com.tw
