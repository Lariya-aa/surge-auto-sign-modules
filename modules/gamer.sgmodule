#!name=Bahamut 每日任务
#!desc=巴哈姆特登录、主页签到、公会签到、动画疯答题
#!author=Codex

[Script]
Bahamut 抓包 = type=http-request, pattern=^https://(www|api|guild|ani)\.gamer\.com\.tw/.*, requires-body=0, script-path=http://192.168.3.11:5580/yara/surge-auto-sign-modules/-/raw/main/scripts/dist/gamer.js, timeout=10
Bahamut 每日任务 = type=cron, cronexp="0 8 * * *", script-path=http://192.168.3.11:5580/yara/surge-auto-sign-modules/-/raw/main/scripts/dist/gamer.js, timeout=300

[MITM]
hostname = %APPEND% www.gamer.com.tw, api.gamer.com.tw, guild.gamer.com.tw, ani.gamer.com.tw
